---
interface Props {
  title: string;
  episode?: string;
  description?: string;
  publishDate: Date;
  coverImage?: string;
  slug: string;
  tags?: string[];
}

const { title, episode, description, publishDate, coverImage, slug, tags } = Astro.props;
---

<article class="mx-auto max-w-3xl px-4 py-12">
  {coverImage && (
    <img
      src={coverImage}
      alt={title}
      class="mb-8 h-72 w-full rounded-xl object-cover shadow-sm"
    />
  )}

  <h1 class="text-4xl font-bold text-neutral-900 mb-4">
    {title}
  </h1>
  {episode && (
    <h5 class="text-lg font-semibold text-neutral-700 mb-4">
      Episode {episode}
    </h5>
  )}

  <div class="flex items-center gap-4 text-neutral-600 mb-6">
    <time class="text-sm">
      { publishDate.toLocaleDateString("nl-BE") }
    </time>
||
    {tags && (
      <ul class="flex gap-2">
        {tags.map((tag) => (
          <li class="rounded-full bg-neutral-100 px-3 py-1 text-xs text-neutral-700">
            {tag}
          </li>
        ))}
      </ul>
    )}
  </div>

  <div class="prose prose-neutral max-w-none">
    <slot />
  </div>
</article>
