---
interface Props {
  title: string;
  description?: string;
  publishDate: Date;
  slug: string;
  coverImage?: string;
}

const { title, description, publishDate, slug, coverImage } = Astro.props;
---

<article class="group rounded-xl border border-neutral-200 bg-white p-5 shadow-sm transition hover:shadow-md">
  <a href={`/blog/${slug}`} class="block">
    {coverImage && (
      <img
        src={coverImage}
        alt={title}
        class="mb-4 h-48 w-full rounded-lg object-cover"
      />
    )}

    <h2 class="text-xl font-semibold text-neutral-900 group-hover:text-neutral-700">
      {title}
    </h2>

    <time class="block mt-1 text-sm text-neutral-500">
      {/* publishDate.toLocaleDateString("nl-BE")} */}
    </time>

    {description && (
      <p class="mt-3 text-neutral-700">
        {description}
      </p>
    )}
  </a>
</article>
