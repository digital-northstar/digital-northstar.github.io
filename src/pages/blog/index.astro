---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogSection from "../../components/blog/BlogSection.astro"

const title = 'Digital Northstar | Blog';

const posts = await getCollection('blogposts');

let selectedPosts = posts.filter(post => new Date(post.data.publishDate).valueOf() <= new Date().valueOf());

let sortedPosts = selectedPosts.sort((a, b) => new Date(a.data.publishDate).valueOf() - new Date(b.data.publishDate).valueOf());

---

<Layout title={title} >
    <BlogSection posts={sortedPosts} />
</Layout>
